# Приложение
APP_NAME=ARTHELLO Finance Dashboard
APP_ENV=production
DEBUG=false

# База данных (async PostgreSQL). На Railway возьми DATABASE_URL из плагина
# Postgres и замени схему "postgresql://" на "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://arthello:arthello@localhost:5432/arthello_finance

# Безопасность
SECRET_KEY=замените_на_случайную_строку_минимум_32_символа
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Telegram уведомления для approve.
# Если TOKEN = "placeholder" или пустой — отправка пропускается (логируется).
TELEGRAM_BOT_TOKEN=placeholder
TELEGRAM_CHAT_ID=

# CORS (через запятую или *)
CORS_ORIGINS=*

# Расписание
BANK_SYNC_INTERVAL_MINUTES=30
DAILY_REPORT_HOUR=9
