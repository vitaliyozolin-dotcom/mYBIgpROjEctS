# Приложение
APP_NAME=ARTHELLO Finance Dashboard
APP_ENV=production
DEBUG=false

# База данных (async PostgreSQL). На Railway возьми DATABASE_URL из плагина
# Postgres и замени схему "postgresql://" на "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://arthello:arthello@localhost:5432/arthello_finance

# Безопасность
SECRET_KEY=замените_на_случайную_строку_минимум_32_символа
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Telegram уведомления для approve.
# Если TOKEN = "placeholder" или пустой — отправка пропускается (логируется).
TELEGRAM_BOT_TOKEN=placeholder
TELEGRAM_CHAT_ID=

# CORS (через запятую или *)
CORS_ORIGINS=*

# Расписание
BANK_SYNC_INTERVAL_MINUTES=30
DAILY_REPORT_HOUR=9
TOCHKA_SYNC_INTERVAL_HOURS=2

# Точка OAuth2 (https://enter.tochka.com/api/v1/)
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
TOCHKA_REDIRECT_URL=https://mybigprojects-production.up.railway.app/api/auth/tochka/callback
# По умолчанию — Keycloak-реалм Точки. Если в личном кабинете указан
# другой URL (например, https://id.tochka.com/oauth2/authorize) —
# переопределите оба значения.
TOCHKA_AUTHORIZE_URL=https://id.tochka.com/realms/tochka/protocol/openid-connect/auth
TOCHKA_TOKEN_URL=https://id.tochka.com/realms/tochka/protocol/openid-connect/token
TOCHKA_API_BASE=https://enter.tochka.com/api/v1
TOCHKA_SCOPE=account_info balances statements
